# Normalize text files in the repository.
* text=auto

# Project text formats should stay LF even on Windows.
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Binary assets should never be line-ending-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
